{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2019",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./plugin/build",
    "rootDir": "./plugin/src",
    "declaration": true
  },
  "include": ["./plugin/src"],
  "exclude": ["./plugin/src/__tests__/*"]
}
